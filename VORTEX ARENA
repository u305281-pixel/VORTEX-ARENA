<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VORTEX ARENA | Official Esports</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@900&family=Inter:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body { background-color: #050505; color: white; font-family: 'Inter', sans-serif; }
        .cyber-font { font-family: 'Orbitron', sans-serif; }
        .neon-text { text-shadow: 0 0 10px #39FF14; color: #39FF14; }
        .glass { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); }
        .btn-neon { background: #39FF14; color: black; font-weight: 900; transition: 0.3s; clip-path: polygon(10% 0, 100% 0, 90% 100%, 0% 100%); }
        .btn-neon:hover { transform: scale(1.05); box-shadow: 0 0 20px #39FF14; }
    </style>
</head>
<body class="overflow-x-hidden">

    <nav class="flex justify-between items-center p-6 border-b border-white/10 sticky top-0 z-50 bg-[#050505]/80">
        <div class="cyber-font text-2xl italic tracking-tighter uppercase font-black">VORTEX<span class="neon-text">ARENA</span></div>
        <div class="text-[10px] tracking-[0.3em] font-bold uppercase text-gray-400">Status: <span class="text-green-500">Online</span></div>
    </nav>

    <section class="py-20 px-6 text-center">
        <h1 class="cyber-font text-6xl md:text-8xl italic uppercase leading-none mb-6">DOMİNE <br> <span class="neon-text underline">ET.</span></h1>
        <p class="text-gray-500 text-sm tracking-widest uppercase mb-10">Amatörlerin bittiği, profesyonellerin başladığı yer.</p>
        <button class="btn-neon px-12 py-4">TAKIMA KATIL</button>
    </section>

    <section class="px-6 mb-20">
        <div class="glass p-6 rounded-2xl relative overflow-hidden">
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-[#39FF14] opacity-10 blur-3xl"></div>
            <h3 class="cyber-font text-lg mb-4 text-[#39FF14]">GELECEK MAÇ</h3>
            <div class="flex justify-between items-center">
                <div class="text-center">
                    <div class="text-4xl">🐺</div>
                    <div class="text-[10px] mt-2 font-bold">VORTEX</div>
                </div>
                <div class="cyber-font text-2xl opacity-50 italic">VS</div>
                <div class="text-center text-gray-600">
                    <div class="text-4xl opacity-50">?</div>
                    <div class="text-[10px] mt-2 font-bold">TBD</div>
                </div>
            </div>
            <div class="mt-6 pt-4 border-t border-white/5 text-center text-xs tracking-tighter text-gray-400 uppercase">
                15 Mart 2024 - 21:00 (TSİ) | Turnuva: Pro League S1
            </div>
        </div>
    </section>

    <section class="px-6 mb-20">
        <h2 class="cyber-font text-xl mb-8 border-l-4 border-[#39FF14] pl-4 uppercase">Aktif Operasyon Kadrosu</h2>
        <div class="grid grid-cols-1 gap-4">
            <div class="glass flex items-center p-4 rounded-xl border-l-4 border-[#39FF14]">
                <div class="w-12 h-12 bg-gray-800 rounded flex items-center justify-center text-xl mr-4">🥷</div>
                <div>
                    <h4 class="cyber-font text-sm">GHOST_WALKER</h4>
                    <p class="text-[10px] text-gray-500 uppercase italic">Entry Fragger / %78 HS Rate</p>
                </div>
            </div>
             <div class="glass flex items-center p-4 rounded-xl border-l-4 border-white/20">
                <div class="w-12 h-12 bg-gray-800 rounded flex items-center justify-center text-xl mr-4">🎯</div>
                <div>
                    <h4 class="cyber-font text-sm">REAPER_AWP</h4>
                    <p class="text-[10px] text-gray-500 uppercase italic">Sniper / Map Control</p>
                </div>
            </div>
        </div>
    </section>

    <footer class="p-10 text-center border-t border-white/5">
        <div class="cyber-font text-xs opacity-30">VORTEX ARENA © 2024 <br> NO BUDGET - PURE SKILL</div>
    </footer>

</body>
</html>
